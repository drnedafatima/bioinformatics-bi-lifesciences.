  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.1 Dataset: Diabetes Clinical Data (PIMA)\n",
    "We use the PIMA Indians Diabetes dataset (768 patients, 8 clinical features) as a representative clinical classification problem."
   ],
   "id": "section1"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load dataset — download from datasets/ folder or fetch directly\n",
    "url = 'https://raw.githubusercontent.com/jbrownlee/Datasets/master/pima-indians-diabetes.data.csv'\n",
    "columns = ['Pregnancies','Glucose','BloodPressure','SkinThickness',\n",
    "           'Insulin','BMI','DiabetesPedigree','Age','Outcome']\n",
    "\n",
    "df = pd.read_csv(url, names=columns)\n",
    "print(f'Dataset shape: {df.shape}')\n",
    "df.head()"
   ],
   "id": "load-data"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.2 Exploratory Data Analysis"
   ],
   "id": "eda-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Class distribution\n",
    "print('Class distribution:')\n",
    "print(df['Outcome'].value_counts())\n",
    "\n",
    "# Correlation heatmap\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.heatmap(df.corr(), annot=True, fmt='.2f', cmap='coolwarm')\n",
    "plt.title('Feature Correlation Matrix — Diabetes Dataset')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "id": "eda"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.3 Preprocessing and Feature Selection"
   ],
   "id": "preprocess-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X = df.drop('Outcome', axis=1)\n",
    "y = df['Outcome']\n",
    "\n",
    "# Replace zero values in clinical columns with median (biologically invalid zeros)\n",
    "cols_with_zeros = ['Glucose','BloodPressure','SkinThickness','Insulin','BMI']\n",
    "for col in cols_with_zeros:\n",
    "    X[col] = X[col].replace(0, X[col].median())\n",
    "\n",
    "# Feature selection — ANOVA F-test\n",
    "selector = SelectKBest(f_classif, k=6)\n",
    "X_selected = selector.fit_transform(X, y)\n",
    "selected_features = X.columns[selector.get_support()]\n",
    "print(f'Selected features: {list(selected_features)}')\n",
    "\n",
    "# Scale\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X_selected)\n",
    "\n",
    "# Split\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_scaled, y, test_size=0.2, random_state=42, stratify=y\n",
    ")"
   ],
   "id": "preprocess"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.4 Classification: Random Forest, SVM, Logistic Regression"
   ],
   "id": "classification-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "models = {\n",
    "    'Random Forest': RandomForestClassifier(n_estimators=100, random_state=42),\n",
    "    'SVM (RBF)': SVC(kernel='rbf', probability=True, random_state=42),\n",
    "    'Logistic Regression': LogisticRegression(random_state=42)\n",
    "}\n",
    "\n",
    "results = {}\n",
    "for name, model in models.items():\n",
    "    model.fit(X_train, y_train)\n",
    "    y_pred = model.predict(X_test)\n",
    "    y_prob = model.predict_proba(X_test)[:, 1]\n",
    "    auc = roc_auc_score(y_test, y_prob)\n",
    "    cv_score = cross_val_score(model, X_scaled, y, cv=5, scoring='roc_auc').mean()\n",
    "    results[name] = {'AUC': round(auc, 3), 'CV AUC (5-fold)': round(cv_score, 3)}\n",
    "    print(f'\\n--- {name} ---')\n",
    "    print(classification_report(y_test, y_pred))\n",
    "\n",
    "print('\\nSummary:')\n",
    "pd.DataFrame(results).T"
   ],
   "id": "classification"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.5 Dimensionality Reduction with PCA"
   ],
   "id": "pca-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "pca = PCA(n_components=2)\n",
    "X_pca = pca.fit_transform(X_scaled)\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1],\n",
    "                      c=y, cmap='coolwarm', alpha=0.6, edgecolors='k', linewidths=0.3)\n",
    "plt.colorbar(scatter, label='Diabetes Outcome')\n",
    "plt.xlabel(f'PC1 ({pca.explained_variance_ratio_[0]*100:.1f}% variance)')\n",
    "plt.ylabel(f'PC2 ({pca.explained_variance_ratio_[1]*100:.1f}% variance)')\n",
    "plt.title('PCA of Diabetes Clinical Features')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "id": "pca"
  },
